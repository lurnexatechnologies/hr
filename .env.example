SECRET_KEY=generate_your_secure_random_key_here
DEBUG=False
ALLOWED_HOSTS=lurnexa.com,www.lurnexa.com

# DynamoDB Configuration
# Leave this blank for AWS production, or set to http://127.0.0.1:8001 for local DynamoDB testing
DYNAMODB_ENDPOINT_URL=http://127.0.0.1:8001

# AWS Credentials (Required if not using IAM Roles on EC2)
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password
DEFAULT_FROM_EMAIL=onboarding@lurnexa.com
